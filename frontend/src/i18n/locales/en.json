  "firstAid": {
    "title": "Full First Aid Guide",
    "subtitle": "MedAgent Emergency Protocols",
    "backToAll": "Back to All Guides",
    "protocolStepByStep": "Protocol Step-by-Step",
    "ahaVerified": "AHA Verified Protocol",
    "emergencyWarning": "Immediately call emergency services if the victim is unresponsive or has trouble breathing. Data here is for instruction only.",
    "upcomingSlots": "Upcoming Slots",
    "available": "AVAILABLE",
    "cpr": {
      "title": "Cardiac Arrest (CPR)",
      "step1": "Check surroundings for safety.",
      "step2": "Tap shoulder and shout to check responsiveness.",
      "step3": "Call emergency services immediately (911/112/999).",
      "step4": "Start chest compressions: Push hard and fast in the center of the chest (100-120 per minute).",
      "step5": "Allow the chest to recoil fully between compressions.",
      "step6": "Continue until professional help arrives or an AED is available."
    },
    "choking": {
      "title": "Severe Choking",
      "step1": "If the person is coughing forcefully, encourage them to continue.",
      "step2": "If they cannot breathe, cough, or speak, stand behind them.",
      "step3": "Perform the Heimlich Maneuver: Give 5 quick abdominal thrusts just above the navel.",
      "step4": "Repeat until the object is forced out or the person becomes unconscious.",
      "step5": "If unconscious, start CPR and look for the object during breaths."
    },
    "bleeding": {
      "title": "Severe Bleeding",
      "step1": "Apply direct pressure to the wound with a clean cloth or sterile bandage.",
      "step2": "Maintain pressure until the bleeding stops.",
      "step3": "If bleeding is life-threatening and on a limb, apply a tourniquet 2-3 inches above the wound.",
      "step4": "Tighten until bleeding stops completely.",
      "step5": "Do not remove the tourniquet; wait for medical professionals."
    },
    "stroke": {
      "title": "Stroke (FAST)",
      "step1": "Face: Ask them to smile. Does one side of the face droop?",
      "step2": "Arms: Ask them to raise both arms. Does one drift downward?",
      "step3": "Speech: Ask them to repeat a simple phrase. Is their speech slurred?",
      "step4": "Time: If any of these are present, call emergency services immediately.",
      "step5": "Keep the person calm and do not give them food or water."
    },
    "anaphylaxis": {
      "title": "Allergic Reaction",
      "step1": "Identify signs of anaphylaxis: Swelling, difficulty breathing, or rapid pulse.",
      "step2": "Ask if they have an EpiPen or auto-injector.",
      "step3": "Inject into the outer mid-thigh and hold for 3-10 seconds.",
      "step4": "Call emergency services even if symptoms improve.",
      "step5": "Record the time of the injection for the medical team."
    }
  },
